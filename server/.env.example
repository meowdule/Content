# 복사 후 .env 로 저장하고 값을 채우세요 (.env 는 git 에 올리지 마세요)

# 수정·삭제 시 필요한 관리 비밀번호 (클라이언트에 넣지 말 것)
ADMIN_PASSWORD=

# GitHub 저장소에 public-submissions.json 을 커밋하기 위한 토큰 (repo 권한, Contents 읽기/쓰기)
GITHUB_TOKEN=

# 대상 저장소 (예: meowdule / Content 는 GITHUB_OWNER=meowdule, GITHUB_REPO=Content)
GITHUB_OWNER=
GITHUB_REPO=

# API 서버 포트
PORT=3847

# 브라우저 출처 허용. 프로덕션에서는 사이트 URL 로 제한 추천 (예: https://meowdule.github.io)
CORS_ORIGIN=*

# 커밋할 파일 경로 (저장소 루트 기준)
SUBMISSIONS_PATH=data/public-submissions.json

# 기본 브랜치
GIT_BRANCH=main
